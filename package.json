{
  "name": "@purecontext/litestream",
  "version": "0.2.5",
  "description": "Litestream sidecar for SQLite backup — shared across Pure Context projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "restore": "node dist/restore.js",
    "prepublishOnly": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/purecontext-dev/purecontext-litestream.git"
  },
  "license": "MIT",
  "keywords": [
    "litestream",
    "sqlite",
    "backup",
    "replication",
    "s3"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome"]
  }
}
